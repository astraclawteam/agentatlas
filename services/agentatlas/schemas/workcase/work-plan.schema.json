{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentatlas.dev/schemas/workcase/work-plan.schema.json",
  "title": "AgentAtlas WorkPlan v1",
  "description": "One revision of a WorkCase's plan. Revision is immutable once the plan has been approved or execution has begun: a changed plan is always a new WorkPlan at a higher revision, never a mutation of an in-flight one. Step.action's authoritative shape lives in schemas/workcase/action.schema.json so it is intentionally shallow here rather than duplicated.",
  "$ref": "#/$defs/WorkPlan",
  "$defs": {
    "StepStatus": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed"]
    },
    "EvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handle", "content_hash", "authority"],
      "description": "Opaque, content-addressed pointer to evidence collected during a Step. Never carries raw content.",
      "properties": {
        "handle": { "type": "string", "minLength": 1, "maxLength": 512 },
        "content_hash": { "type": "string", "minLength": 1, "maxLength": 256 },
        "authority": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "ReceiptRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handle", "receipt_hash", "signature_key_id"],
      "description": "Opaque, content-addressed pointer to the signed receipt produced when an ActionSpec executes. Never carries raw content.",
      "properties": {
        "handle": { "type": "string", "minLength": 1, "maxLength": 512 },
        "receipt_hash": { "type": "string", "minLength": 1, "maxLength": 256 },
        "signature_key_id": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "Step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "status": { "$ref": "#/$defs/StepStatus", "default": "pending" },
        "evidence": {
          "type": "array",
          "default": [],
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/EvidenceRef" }
        },
        "action": {
          "type": "object",
          "description": "Authoritative shape is schemas/workcase/action.schema.json#/$defs/ActionSpec. A Step with no action is a checkpoint (for example a human confirmation)."
        }
      }
    },
    "WorkPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "steps"],
      "properties": {
        "revision": { "type": "integer", "minimum": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Step" }
        }
      }
    }
  }
}
