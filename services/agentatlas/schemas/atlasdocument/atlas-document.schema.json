{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentatlas.org/atlasdocument/atlas-document.schema.json",
  "title": "AtlasDocument v1",
  "description": "Normalized intermediate parse result. The full document lives in object storage; AgentAtlas metadata tables keep only hashes, sanitized summaries, and evidence pointers.",
  "type": "object",
  "required": ["atlas_document_id", "artifact_id", "source_hash", "content_type"],
  "properties": {
    "atlas_document_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "source_hash": { "type": "string", "minLength": 1 },
    "content_type": { "type": "string" },
    "provider": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["block_id", "type", "order"],
        "properties": {
          "block_id": { "type": "string" },
          "type": { "enum": ["text", "heading", "table", "figure", "caption", "list", "code"] },
          "order": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1 },
          "text": { "type": "string" },
          "bbox": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          }
        },
        "additionalProperties": false
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["table_id"],
        "properties": {
          "table_id": { "type": "string" },
          "page": { "type": "integer", "minimum": 1 },
          "n_rows": { "type": "integer", "minimum": 0 },
          "n_cols": { "type": "integer", "minimum": 0 },
          "cells": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["row", "col", "text"],
              "properties": {
                "row": { "type": "integer", "minimum": 0 },
                "col": { "type": "integer", "minimum": 0 },
                "text": { "type": "string" },
                "rowspan": { "type": "integer", "minimum": 1 },
                "colspan": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": false
            }
          },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["image_id"],
        "properties": {
          "image_id": { "type": "string" },
          "page": { "type": "integer", "minimum": 1 },
          "bbox": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "object_key": { "type": "string", "description": "Object storage key of the cropped region" },
          "ocr_text": { "type": "string" },
          "vlm_caption": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "audio_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "start_ms", "end_ms"],
        "properties": {
          "segment_id": { "type": "string" },
          "start_ms": { "type": "integer", "minimum": 0 },
          "end_ms": { "type": "integer", "minimum": 0 },
          "speaker": { "type": "string" },
          "text": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "video_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "start_ms", "end_ms"],
        "properties": {
          "segment_id": { "type": "string" },
          "start_ms": { "type": "integer", "minimum": 0 },
          "end_ms": { "type": "integer", "minimum": 0 },
          "scene_index": { "type": "integer", "minimum": 0 },
          "keyframe_object_key": { "type": "string" },
          "transcript": { "type": "string" },
          "keyframe_caption": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["summary_id", "level", "text"],
        "properties": {
          "summary_id": { "type": "string" },
          "level": { "enum": ["section", "document", "display", "retrieval"] },
          "ref": { "type": "string", "description": "block/section/segment the summary covers" },
          "text": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "evidence_pointers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["enterprise_id", "resource_type", "resource_ref", "source_system"],
        "properties": {
          "evidence_id": { "type": "string" },
          "enterprise_id": { "type": "string" },
          "resource_type": { "type": "string" },
          "resource_ref": { "type": "string" },
          "source_system": { "type": "string" },
          "content_hash": { "type": "string" },
          "summary_hash": { "type": "string" },
          "agentnexus_resource_uri": { "type": "string" },
          "required_scopes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
