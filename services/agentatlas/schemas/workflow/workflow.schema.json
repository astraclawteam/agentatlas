{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentatlas.org/workflow/workflow.schema.json",
  "title": "AgentAtlas Workflow v1",
  "type": "object",
  "required": ["workflow_id", "version", "kind", "nodes", "edges", "risk_level"],
  "properties": {
    "workflow_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 0 },
    "kind": { "enum": ["sop", "dream", "ingestion", "answer"] },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "variables": { "type": "object" },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "risk_level": { "enum": ["low", "medium", "high"] }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "input.manual",
            "input.evidence_pointer",
            "parser.document",
            "parser.image",
            "parser.long_image",
            "parser.audio",
            "parser.video",
            "transform.extract_sop",
            "transform.summarize",
            "retrieval.search",
            "nexus.locate",
            "nexus.read",
            "human.confirm",
            "dream.aggregate",
            "answer.generate",
            "trace.append"
          ]
        },
        "name": { "type": "string" },
        "config": { "type": "object" },
        "requires_confirmation": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "condition": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
