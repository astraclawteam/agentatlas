# Copy to .env and adjust. All components are production-standard; there is
# no lightweight substitute profile.

# --- credentials ---
POSTGRES_PASSWORD=atlas
MINIO_ROOT_USER=atlas
MINIO_ROOT_PASSWORD=atlas-secret-key

# --- pinned images (verified 2026-07-06; compose defaults pin by digest) ---
POSTGRES_IMAGE=postgres:17-alpine
OPENSEARCH_VERSION=3.7.0
NATS_IMAGE=nats:2.11-alpine
MINIO_IMAGE=minio/minio@sha256:14cea493d9a34af32f524e538b8346cf79f3321eff8e708c1e2960462bd8936e
MC_IMAGE=minio/mc@sha256:a7fe349ef4bd8521fb8497f55c6042871b2ae640607cf99d9bede5e9bdf11727
# Official image, reachable on both ghcr.io and quay.io (digest-pinned).
DOCLING_IMAGE=ghcr.io/docling-project/docling-serve@sha256:56189f190892cc03a4a5c10ba9e56c421ac2524554aa2d36f0f4bb6564132524
# MinerU has no official registry image; mineru-sidecar builds from PyPI.

# --- model access (OpenAI-compatible; llmrouter is the default deployment) ---
# Point this at a router this stack can actually reach. Leaving it empty is a
# supported degraded mode, not a failure: the services start and report
# ready=false at /healthz naming this variable. There is no default endpoint on
# purpose — one that resolves to nothing looks configured and is not.
LLMROUTER_BASE_URL=
LLMROUTER_API_KEY=
# Rerank model served at {base_url}/rerank (Cohere-style contract).
ATLAS_LLMROUTER_RERANK_MODEL=bge-reranker

# --- AgentNexus (mock server for local development, Goal 5+) ---
NEXUS_BASE_URL=http://host.docker.internal:8100
# Enterprises whose org-event streams atlas-worker subscribes for space sync
# (comma-separated; the real-stack e2e uses ent_realstack).
ATLAS_ORG_SYNC_ENTERPRISES=

# --- sidecar tuning ---
WHISPER_MODEL=small
WHISPER_DEVICE=auto

# --- build-time mirrors (China networks) ---
GOPROXY_BUILD=https://proxy.golang.org,direct
PIP_INDEX_URL=https://pypi.org/simple
# Examples for China: GOPROXY_BUILD=https://goproxy.cn,direct
#                     PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
