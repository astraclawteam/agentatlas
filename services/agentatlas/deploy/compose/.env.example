# Copy to .env and adjust. All components are production-standard; there is
# no lightweight substitute profile.

# --- credentials ---
POSTGRES_PASSWORD=atlas
MINIO_ROOT_USER=atlas
MINIO_ROOT_PASSWORD=atlas-secret-key

# --- pinned images (verified 2026-07-06) ---
POSTGRES_IMAGE=postgres:17-alpine
OPENSEARCH_VERSION=3.7.0
NATS_IMAGE=nats:2.11-alpine
MINIO_IMAGE=minio/minio:latest
MC_IMAGE=minio/mc:latest
# Official image, reachable on both ghcr.io and quay.io.
DOCLING_IMAGE=ghcr.io/docling-project/docling-serve:latest
# MinerU has no official registry image; mineru-sidecar builds from PyPI.

# --- model access (OpenAI-compatible; llmrouter is the default deployment) ---
LLMROUTER_BASE_URL=http://host.docker.internal:8000/v1
LLMROUTER_API_KEY=
# Rerank model served at {base_url}/rerank (Cohere-style contract).
ATLAS_LLMROUTER_RERANK_MODEL=bge-reranker

# --- AgentNexus (mock server for local development, Goal 5+) ---
NEXUS_BASE_URL=http://host.docker.internal:8100

# --- sidecar tuning ---
WHISPER_MODEL=small
WHISPER_DEVICE=auto

# --- build-time mirrors (China networks) ---
GOPROXY_BUILD=https://proxy.golang.org,direct
PIP_INDEX_URL=https://pypi.org/simple
# Examples for China: GOPROXY_BUILD=https://goproxy.cn,direct
#                     PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
